{
  "name": "starface-bq-mcp",
  "version": "1.0.0",
  "private": true,
  "description": "Local MCP server that connects Claude Desktop to the Starface BigQuery datalake (read-only).",
  "type": "module",
  "bin": {
    "starface-bq-mcp": "dist/server.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/server.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/server.js --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.9.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.0"
  }
}
